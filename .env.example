# Resend — required for the lead-form email pipeline
RESEND_API_KEY=
RESEND_FROM=leads@quadgrowth.com.au
LEAD_EMAIL_TO=ecuadra@quadgrowth.com.au

# reCAPTCHA v2 site key (public, safe to expose)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LcPvrYsAAAAAHn3L4rBXZN28F44HKgxPUzyigX-

# Optional: enable server-side reCAPTCHA verification.
# When set, /api/lead calls https://www.google.com/recaptcha/api/siteverify.
# Leave empty to rely on the client-side checkbox + honeypot + math/timing checks only.
RECAPTCHA_SECRET_KEY=

# Site origin used in metadata, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://quadgrowth.com.au
